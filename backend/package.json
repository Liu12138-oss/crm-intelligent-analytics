{
  "name": "crm-intelligent-analytics-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ..\\scripts\\run-backend-dev.ps1",
    "dev:raw": "node --watch -r ts-node/register src/main.ts",
    "dev:once": "node -r ts-node/register src/main.ts",
    "dev:watch": "node --watch -r ts-node/register src/main.ts",
    "build": "tsc -p tsconfig.json",
    "benchmark:ai-reasoning": "tsx scripts/benchmark-ai-reasoning.ts",
    "start": "node dist/src/main.js",
    "test": "jest --runInBand",
    "lint": "set ESLINT_USE_FLAT_CONFIG=false&& eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "verify:runtime": "tsx scripts/verify-runtime.ts",
    "verify:analysis-warehouse": "set NODE_ENV=development&& node -r ts-node/register scripts/verify-analysis-warehouse.ts",
    "snapshot:openapi-markdown": "tsx scripts/generate-openapi-markdown-snapshot.ts",
    "classify:query-template-scopes": "tsx scripts/classify-query-template-scopes.ts",
    "accept:crm-analysis-300-strict": "ts-node scripts/accept-crm-analysis-300-strict.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@wecom/aibot-node-sdk": "^1.0.4",
    "cookie-parser": "^1.4.7",
    "mysql2": "^3.12.0",
    "node-sql-parser": "^5.3.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "sql.js": "^1.14.1",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.24",
    "@types/sql.js": "^1.4.11",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
