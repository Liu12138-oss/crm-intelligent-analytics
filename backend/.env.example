# 后端本地环境变量模板
# 说明：
# 1. 请只在本机 .env 中填写真实值，不要把真实密钥、密码提交到仓库。
# 2. AI 网关配置来源：配置/codex配置/config.toml 与 配置/codex配置/auth.json
# 3. 企业微信配置来源：配置/企业微信/ID和密钥.md
# 4. CRM 只读库配置来源：配置/数据库/数据库账号密码.txt
# 5. 应用库如暂未启用，可先保留占位值。

# 服务监听端口
PORT=3001

# CRM 只读数据库
CRM_WRITEBACK_DB_HOST=crm_host_from_config
CRM_READONLY_DB_PORT=3306
CRM_READONLY_DB_NAME=crm_database_from_config
CRM_READONLY_DB_USER=crm_user_from_config
CRM_READONLY_DB_PASSWORD=replace_with_real_crm_password
CRM_READONLY_DB_CONNECT_TIMEOUT_MS=60000

# CRM 写回数据源（可选）
# 说明：
# 1. 企业微信目录同步和后续写入型能力可单独配置写回账号。
# 2. 如未配置，运行时默认回退到 CRM_READONLY_DB_*。
#CRM_WRITEBACK_DB_HOST=crm_host_from_config
#CRM_WRITEBACK_DB_PORT=3306
#CRM_WRITEBACK_DB_NAME=crm_database_from_config
#CRM_WRITEBACK_DB_USER=crm_writeback_user
#CRM_WRITEBACK_DB_PASSWORD=replace_with_real_crm_writeback_password

# CRM Open API 认证
CRM_OPEN_API_BASE_URL=http://your-crm-open-api-host
CRM_OPEN_API_CORP_ID=replace_with_crm_corp_id
CRM_OPEN_API_VERSION_CODE=9.9.9
CRM_OPEN_API_DEVICE=open_api
CRM_OPEN_API_TIMEOUT_MS=12000
CRM_AUTH_MOCK_ENABLED=false

# CRM 标准只读开放接口（第一阶段企微问数使用）
# 说明：
# 1. 该组配置使用对方最新 appKey/appSecret 口径。
# 2. 运行后也可在前端“联调管理”页保存和测试，页面保存会覆盖这里的兜底值。
CRM_STANDARD_OPEN_API_BASE_URL=http://your-crm-open-api-host/api/open/v1
CRM_STANDARD_OPEN_API_APP_KEY=replace_with_standard_open_api_app_key
CRM_STANDARD_OPEN_API_APP_SECRET=replace_with_standard_open_api_app_secret
CRM_STANDARD_OPEN_API_TIMEOUT_MS=12000
CRM_STANDARD_OPEN_API_TOKEN_CACHE_BUFFER_SECONDS=60
CRM_STANDARD_OPEN_API_ACCESS_MODE=bound-user
# 企业微信受控写入内置账号
# 说明：
# 1. 用于企业微信机器人受控跟进写回、受控新增客户和受控新增商机时换取 CRM Open API token。
# 2. 不用于 Web 登录，也不应写入真实账号密码到仓库。
CRM_OPEN_API_WRITEBACK_LOGIN=crm_builtin_writeback_login
CRM_OPEN_API_WRITEBACK_PASSWORD=replace_with_real_crm_builtin_writeback_password

# 应用存储数据库
APP_STORAGE_DB_HOST=app_storage_host
APP_STORAGE_DB_PORT=3306
APP_STORAGE_DB_NAME=app_storage_database
APP_STORAGE_DB_USER=app_storage_user
APP_STORAGE_DB_PASSWORD=replace_with_app_storage_password

# 合同审核存储
# 说明：
# 1. 原始合同与审核产物默认落到后端本地目录。
# 2. 生产环境建议挂载独立持久化目录，并做好容量监控与访问隔离。
CONTRACT_REVIEW_STORAGE_DIR=.runtime/contract-review
CONTRACT_REVIEW_MAX_FILE_SIZE_MB=10
CONTRACT_REVIEW_AI_TIMEOUT_MS=150000
CONTRACT_REVIEW_AI_MAX_PARALLEL_GROUPS=1
CONTRACT_REVIEW_AI_SUPPLEMENTAL_TIMEOUT_MS=45000
CONTRACT_REVIEW_AI_SUPPLEMENTAL_MAX_CHECKS_PER_BATCH=1
CONTRACT_REVIEW_REVIEWER_ROLE_IDS=role_admin
CONTRACT_REVIEW_DOWNLOADER_ROLE_IDS=role_admin

# AI 网关
# 说明：
# 1. 当前系统同时支持“环境默认 AI 配置”和“后台 AI Profile 治理配置”两套来源。
# 2. 当后台存在已激活 Profile 时，企业微信机器人普通 AI 对话优先读取后台激活配置。
# 3. 当后台没有激活 Profile 时，系统回退到以下环境变量作为默认 AI 配置。
# 4. `AI_PROFILE_MASTER_KEY` 用于加密后台保存的 AI 密钥；生产环境必须显式配置，开发环境未配置时会回退到 `.runtime/ai-profile-master.key`。
AI_PROFILE_MASTER_KEY=replace_with_random_32_char_secret
ANALYSIS_AI_BASE_URL=ai_base_url_from_config
ANALYSIS_AI_MODEL_PROVIDER=model_provider_from_config
ANALYSIS_AI_MODEL=model_name_from_config
ANALYSIS_AI_REASONING_EFFORT=none
ANALYSIS_AI_SERVICE_TIER=fast
ANALYSIS_AI_WIRE_API=responses
ANALYSIS_AI_REQUIRES_OPENAI_AUTH=true
ANALYSIS_AI_DISABLE_RESPONSE_STORAGE=true
# ANALYSIS_AI_CODEX_PATH=codex
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost
OPENAI_API_KEY=replace_with_value_from_auth_json
# Claude Agent SDK（后台 AI Profile 兼容字段）
# 说明：
# 1. 以下变量会在后台“AI 模型”页初始化时自动识别为“环境默认 Claude Profile”。
# 2. 若缺少 `ANTHROPIC_MODEL` 等关键字段，治理页会展示“待补齐”提示，补齐后可直接在抽屉中点击“测试连接”。
# 3. 正式切换推荐通过后台“AI 模型”治理页单选启用，不建议长期直接写死在 .env.local。
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-gateway
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_REASONING_EFFORT=low
# ANTHROPIC_API_KEY=replace_with_real_claude_key
# ANTHROPIC_AUTH_TOKEN=replace_with_real_claude_auth_token

# 企业微信机器人
WECOM_BOT_ID=replace_with_wecom_bot_id
WECOM_BOT_SECRET=replace_with_wecom_bot_secret
WECOM_BOT_SIGNATURE=replace_with_wecom_signature
WECOM_BOT_SOURCE=wecom-bot
# 本地联调建议 false，正式长连接联调改为 true
WECOM_ENABLE_SDK_TRANSPORT=false
WECOM_BOT_WS_URL=wss://openws.work.weixin.qq.com
WECOM_BOT_MAX_RECONNECT_ATTEMPTS=10
WECOM_BOT_HEARTBEAT_INTERVAL_MS=30000
WECOM_BOT_DELIVERY_MAX_RETRIES=2
WECOM_BOT_DELIVERY_RETRY_DELAY_MS=300
WECOM_BOT_DELIVERY_CHUNK_MAX_LENGTH=900
WECOM_WEB_LOGIN_AUTHORIZE_URL=https://open.work.weixin.qq.com/wwopen/sso/qrConnect?appid=replace_with_wecom_appid&redirect_uri={redirect_uri}&state={state}
WECOM_WEB_LOGIN_CALLBACK_URL=http://127.0.0.1:3001/api/v1/auth/wecom/callback

# 企业微信官方通讯录同步
# 说明：
# 1. 使用企业微信官方通讯录 API，同步源不再使用 EMM。
# 2. 生产环境应优先按最小授权范围配置。
# 3. 当前项目现行约束是：只同步“联软科技集团”授权范围，不应直接放开 ROOT 全量组织树。
# 4. 目录同步直接复用 `WECOM_WEB_LOGIN_APP_ID` / `WECOM_WEB_LOGIN_SECRET`，无需单独配置凭证。
WECOM_DIRECTORY_ROOT_DEPARTMENT_NAME=联软科技集团
# 企业微信官方通讯录同步
# 说明：
# 1. 使用企业微信官方通讯录 API，同步源不再使用 EMM。
# 2. 目录同步建议使用单独的企业微信应用密钥，避免和 Web 登录应用混用导致字段权限不一致。
# 3. corpId 默认可复用 `WECOM_WEB_LOGIN_APP_ID`，但 secret 应使用目录同步专用配置。
# 4. 当前项目现行约束是：只同步“联软科技集团”授权范围，不应直接放开 ROOT 全量组织树。
WECOM_DIRECTORY_ROOT_DEPARTMENT_NAME=联软科技集团
WECOM_DIRECTORY_AGENT_ID=1000043
#WECOM_DIRECTORY_SECRET=replace_with_wecom_directory_secret
WECOM_DIRECTORY_PAGE_SIZE=100

# 说明补充：
# 1. Web 企业微信扫码认证使用 `WECOM_WEB_LOGIN_AGENT_ID` / `WECOM_WEB_LOGIN_SECRET`。
# 2. 组织架构同步使用 `WECOM_DIRECTORY_AGENT_ID` / `WECOM_DIRECTORY_SECRET`。
# 3. 两者继续共用同一个企业微信 corpId（`WECOM_WEB_LOGIN_APP_ID`）。

# 企业微信主动通知
# 说明：
# 1. 未配置 `WECOM_NOTIFY_*` 时，通知底座默认回落到当前自建应用 `WECOM_WEB_LOGIN_*` 配置。
# 2. `WECOM_NOTIFY_REAL_MESSAGE_ENABLED=false` 时，真实业务对象不会收到消息，联调默认改投测试接收人。
WECOM_NOTIFY_CORP_ID=replace_with_wecom_notify_corp_id
WECOM_NOTIFY_AGENT_ID=replace_with_wecom_notify_agent_id
WECOM_NOTIFY_SECRET=replace_with_wecom_notify_secret
WECOM_NOTIFY_REAL_MESSAGE_ENABLED=false
WECOM_NOTIFY_TEST_USER_ID=WangLiang02

# Web 登录态
APP_WEB_BASE_URL=http://127.0.0.1:5173
# 前端构建基路径：根路径部署填 /，子路径部署填 /insight/ 这类带首尾斜杠的路径。
VITE_APP_BASE_PATH=/
CRM_AUTH_SESSION_TTL_HOURS=12

# 新增客户接口默认值与字段映射
# 说明：
# 1. default 字段应填写 CRM `/api/v2/field_maps/customer` 返回的真实值，而不是页面展示文案。
# 2. *_FIELD 需要填写 CRM 自定义字段 key，例如 `text_asset_xxxxxxxx`。
CRM_CUSTOMER_CREATE_DEFAULT_CATEGORY=replace_with_customer_category_value
CRM_CUSTOMER_CREATE_DEFAULT_SOURCE=replace_with_customer_source_value
CRM_CUSTOMER_CREATE_IT_DECISION_LOCATION_FIELD=replace_with_customer_it_decision_location_field_key
CRM_CUSTOMER_CREATE_UNIFIED_SOCIAL_CREDIT_CODE_FIELD=replace_with_customer_uscc_field_key

# 新增商机接口默认值与字段映射
# 说明：
# 1. default 字段应填写 CRM `/api/v2/field_maps/opportunity` 返回的真实值。
# 2. *_FIELD 需要填写 CRM 自定义字段 key，例如 `text_asset_xxxxxxxx`。
# 3. `CRM_OPPORTUNITY_CREATE_PRODUCT_ALIAS_MAP` 仅供企业微信商机创建使用，值为 JSON 对象，键为产品别名，值为对应 `productId`。
CRM_OPPORTUNITY_CREATE_DEFAULT_STAGE=replace_with_opportunity_stage_value
CRM_OPPORTUNITY_CREATE_DEFAULT_SOURCE=replace_with_opportunity_source_value
CRM_OPPORTUNITY_CREATE_DEFAULT_KIND=replace_with_opportunity_kind_value
CRM_OPPORTUNITY_CREATE_LEAD_CODE_FIELD=replace_with_opportunity_lead_code_field_key
CRM_OPPORTUNITY_CREATE_RENEWAL_CONTRACT_CODE_FIELD=replace_with_opportunity_renewal_contract_code_field_key
CRM_OPPORTUNITY_CREATE_AGENT_FULL_NAME_FIELD=replace_with_opportunity_agent_full_name_field_key
CRM_OPPORTUNITY_CREATE_PROJECT_STATUS_FIELD=replace_with_opportunity_project_status_field_key
CRM_OPPORTUNITY_CREATE_PRE_SALES_FIELD=replace_with_opportunity_pre_sales_field_key
CRM_OPPORTUNITY_CREATE_PRODUCT_ALIAS_MAP={"云平台标准版":"replace_with_product_id"}

# 日报功能开关：控制日报催办、日报确认和日报推送。
# 说明：
# 1. `DAILY_REPORT_INTERNAL_SCHEDULER_ENABLED=true` 时，后端应用自身按业务时间触发日报任务，不再依赖外部登录脚本。
# 2. 首次生产联调建议继续保持 `WECOM_NOTIFY_REAL_MESSAGE_ENABLED=false`，实际投递层会改投 `WECOM_NOTIFY_TEST_USER_ID`。
DAILY_REPORT_ENABLED=true
DAILY_REPORT_INTERNAL_SCHEDULER_ENABLED=true
DAILY_REPORT_SCHEDULER_ACTOR_USER_ID=user_admin
DAILY_REPORT_REMINDER_TIME=22:00
DAILY_REPORT_CLOSE_TIME=23:59
DAILY_REPORT_SUMMARY_TIME=08:00

# 受控分析与企业微信 AI 助手灰度开关
# 说明：
# 1. AI_GUARDED_DIRECT_QUERY_ENABLED 默认应保持 false，开启后才允许请求显式进入受控 AI 直查模式。
# 2. 其余 AI 增强开关可按环境灰度关闭；关闭后系统回退到既有计划执行、模板整理、规则候选或事实摘要路径。
AI_GUARDED_DIRECT_QUERY_ENABLED=false
AI_ANALYSIS_FOLLOW_UP_INTENT_ENABLED=true
AI_GROUNDED_EXPLANATION_ENABLED=true
WECOM_AI_ENTRY_INTENT_ENABLED=true
WECOM_AI_STRUCTURED_DRAFT_ENABLED=true
WECOM_AI_ENTITY_RERANK_ENABLED=true
WECOM_AI_DAILY_INSIGHT_ENABLED=true

# 企业微信确认类回复与四段草稿默认优先走 AI 理解；当网关响应较慢时，可单独放宽超时，避免过早回退到 fallback。
WECOM_AI_IDLE_INTENT_TIMEOUT_MS=8000
WECOM_AI_TASK_REPLY_TIMEOUT_MS=8000
WECOM_AI_STRUCTURED_DRAFT_TIMEOUT_MS=8000

# AI-agent 自建分析库
# 说明：
# 1. 该库只用于我方 ODS/DWD/语义层和受控 Text-to-SQL，不允许直接填写联软生产 SQLite 或生产业务库。
# 2. 首次配置后可运行 `pnpm --dir backend verify:analysis-warehouse` 验证建表、落库和受控 SQL。
ANALYSIS_WAREHOUSE_DB_HOST=replace_with_analysis_warehouse_host
ANALYSIS_WAREHOUSE_DB_PORT=3306
ANALYSIS_WAREHOUSE_DB_NAME=crm_agent_analysis
ANALYSIS_WAREHOUSE_DB_USER=replace_with_analysis_warehouse_user
ANALYSIS_WAREHOUSE_DB_PASSWORD=replace_with_analysis_warehouse_password
ANALYSIS_WAREHOUSE_DB_CONNECT_TIMEOUT_MS=8000
ANALYSIS_WAREHOUSE_TEXT_TO_SQL_ENABLED=true
ANALYSIS_WAREHOUSE_SQLITE_ONLY=false

# CRM 分析路线
# 说明：
# 1. openapi 表示通过联软标准 OpenAPI 取数。
# 2. sqlite-readonly 表示直接读取联软渠道 CRM analysis-mirror SQLite 只读镜像库，仍需程序侧权限裁剪、白名单和审计。
# 3. SQLite 路线不使用 AI-agent MySQL 分析库。
# 4. CRM_SQLITE_READONLY_DB_PATH 可填写 analysis-mirror 目录；目录模式优先读取 analysis_mirror_latest.db。
CRM_ANALYSIS_ROUTE=openapi
CRM_SQLITE_READONLY_ENABLED=false
CRM_SQLITE_READONLY_DB_PATH=replace_with_lianruan_crm_backend_analysis_mirror_dir_or_db_file
CRM_SQLITE_READONLY_QUERY_TIMEOUT_MS=10000
CRM_SQLITE_READONLY_MAX_ROWS=5000
CRM_SQLITE_READONLY_MAX_BYTES=536870912

# OpenAPI Markdown 分析快照
# 说明：
# 1. 该能力通过联软标准 OpenAPI 生成 AI 可读 Markdown 文件，用于帮助 AI 理解业务材料。
# 2. 可由后端定时刷新，也可手动执行：pnpm --dir backend snapshot:openapi-markdown。
# 3. AI 只读取 latest 目录下已生成的 Markdown；未生成或关闭时不影响现有分析主链。
CRM_OPENAPI_MARKDOWN_SNAPSHOT_ENABLED=false
CRM_OPENAPI_MARKDOWN_SNAPSHOT_DIR=replace_with_local_analysis_snapshot_dir
CRM_OPENAPI_MARKDOWN_SNAPSHOT_MAX_ROWS=1000
CRM_OPENAPI_MARKDOWN_SNAPSHOT_DETAIL_ROWS=50
CRM_OPENAPI_MARKDOWN_SNAPSHOT_MAX_CONTEXT_CHARS=30000
CRM_OPENAPI_MARKDOWN_SNAPSHOT_REFRESH_ENABLED=false
CRM_OPENAPI_MARKDOWN_SNAPSHOT_REFRESH_ON_STARTUP=true
CRM_OPENAPI_MARKDOWN_SNAPSHOT_REFRESH_INTERVAL_MINUTES=60
