# CRM 智能分析系统生产环境变量模板
# 说明：
# 1. 本文件仅提供键名、示例值和注释，不可直接用于生产。
# 2. 真实密钥、密码、Token、企业微信 Secret 不得提交到仓库。
# 3. 建议将生产文件保存为 /srv/crm-intelligent-analytics/shared/backend.env，
#    并设置权限为 600，仅允许应用用户和受控运维读取。
# 4. VITE_API_BASE_URL / VITE_APP_BASE_PATH 主要用于前端构建阶段，本文件保留它们是为了让发布脚本
#    可以从同一套配置源读取正式地址；后端运行时本身不消费这两个变量。

NODE_ENV=production

# 服务监听
PORT=3001
APP_WEB_BASE_URL=https://analytics.company.com/insight
VITE_API_BASE_URL=https://analytics.company.com/insight
VITE_APP_BASE_PATH=/insight/

# CRM Open API
CRM_OPEN_API_BASE_URL=https://crm-open-api.example.com
CRM_OPEN_API_CORP_ID=replace_with_crm_corp_id
CRM_OPEN_API_LOGIN_PATH=/api/v2/auth/login
CRM_OPEN_API_VERSION_CODE=9.9.9
CRM_OPEN_API_DEVICE=open_api
CRM_OPEN_API_TIMEOUT_MS=12000
CRM_AUTH_MOCK_ENABLED=false

# CRM 真实登录后的身份查询 API
# 说明：用于真实账号登录成功后按 user_id 拉取角色、部门、可见 owner 等权限上下文。
# 若对方身份查询接口与 CRM_OPEN_API_BASE_URL 同域，可只配置路径；若单独部署，请填写独立 Base URL。
CRM_AUTH_IDENTITY_API_BASE_URL=https://crm-open-api.example.com
CRM_AUTH_IDENTITY_API_USER_PATH=/api/open/v1/identity/users/{userId}
CRM_AUTH_IDENTITY_API_AUTH_MODE=crm-token
CRM_AUTH_IDENTITY_API_TIMEOUT_MS=12000

# 联软标准 OpenAPI
# 说明：用于第一阶段六类对象只读查询、权限范围诊断和智能分析数据适配。
CRM_STANDARD_OPEN_API_BASE_URL=http://10.18.16.114:3000/api/open/v1
CRM_STANDARD_OPEN_API_APP_KEY=replace_with_standard_open_api_app_key
CRM_STANDARD_OPEN_API_APP_SECRET=replace_with_standard_open_api_app_secret
CRM_STANDARD_OPEN_API_TIMEOUT_MS=12000
CRM_STANDARD_OPEN_API_TOKEN_CACHE_BUFFER_SECONDS=60

# 企业微信受控写回使用的内置 CRM 账号
CRM_OPEN_API_WRITEBACK_LOGIN=replace_with_crm_writeback_login
CRM_OPEN_API_WRITEBACK_PASSWORD=replace_with_crm_writeback_password

# CRM 只读数据库
CRM_READONLY_DB_HOST=crm-db.example.internal
CRM_READONLY_DB_PORT=3306
CRM_READONLY_DB_NAME=vcooline_ikcrm_production
CRM_READONLY_DB_USER=replace_with_crm_readonly_user
CRM_READONLY_DB_PASSWORD=replace_with_crm_readonly_password
CRM_READONLY_DB_CONNECT_TIMEOUT_MS=60000

# CRM 写回数据库
# 如生产环境仍复用只读库作为写回库，可删除本组并让运行时回退。
CRM_WRITEBACK_DB_HOST=crm-write-db.example.internal
CRM_WRITEBACK_DB_PORT=3306
CRM_WRITEBACK_DB_NAME=vcooline_ikcrm_production
CRM_WRITEBACK_DB_USER=replace_with_crm_write_user
CRM_WRITEBACK_DB_PASSWORD=replace_with_crm_write_password

# AI 默认配置
AI_PROFILE_MASTER_KEY=replace_with_random_secret_at_least_32_chars
ANALYSIS_AI_BASE_URL=https://ai-gateway.example.com/v1
ANALYSIS_AI_MODEL_PROVIDER=internal-openai-gateway
ANALYSIS_AI_MODEL=gpt-4.1
ANALYSIS_AI_REASONING_EFFORT=low
ANALYSIS_AI_SERVICE_TIER=standard
ANALYSIS_AI_WIRE_API=responses
ANALYSIS_AI_STRUCTURED_OUTPUT_MODE=json_schema
ANALYSIS_AI_REQUIRES_OPENAI_AUTH=true
ANALYSIS_AI_DISABLE_RESPONSE_STORAGE=true
OPENAI_API_KEY=replace_with_ai_gateway_key

# 如访问 AI 网关必须走代理，按需打开
# HTTP_PROXY=http://proxy.example.internal:7890
# HTTPS_PROXY=http://proxy.example.internal:7890
# NO_PROXY=127.0.0.1,localhost,.example.internal

# 企业微信机器人
WECOM_BOT_ID=replace_with_wecom_bot_id
WECOM_BOT_SECRET=replace_with_wecom_bot_secret
WECOM_BOT_SIGNATURE=replace_with_wecom_bot_signature
WECOM_BOT_SOURCE=wecom-bot
WECOM_BOT_WS_URL=wss://openws.work.weixin.qq.com
WECOM_BOT_MAX_RECONNECT_ATTEMPTS=10
WECOM_BOT_HEARTBEAT_INTERVAL_MS=30000
WECOM_BOT_DELIVERY_MAX_RETRIES=2
WECOM_BOT_DELIVERY_RETRY_DELAY_MS=60000
WECOM_BOT_PROACTIVE_MIN_INTERVAL_MS=15000
WECOM_BOT_RATE_LIMIT_RETRY_DELAYS_MS=60000,180000,300000
WECOM_BOT_DELIVERY_CHUNK_MAX_LENGTH=900

# 企业微信 Web 登录
WECOM_WEB_LOGIN_APP_ID=replace_with_wecom_corp_id
WECOM_WEB_LOGIN_AGENT_ID=replace_with_wecom_login_agent_id
WECOM_WEB_LOGIN_SECRET=replace_with_wecom_login_secret
WECOM_WEB_LOGIN_CALLBACK_URL=https://analytics.company.com/api/v1/auth/wecom/callback
WECOM_WEB_LOGIN_QR_CONNECT_URL=https://open.work.weixin.qq.com/wwopen/sso/qrConnect
WECOM_QYAPI_BASE_URL=https://qyapi.weixin.qq.com/cgi-bin

# 企业微信通讯录同步
# 注意：建议与 Web 登录使用不同的 agent 和 secret。
WECOM_DIRECTORY_CORP_ID=replace_with_wecom_corp_id
WECOM_DIRECTORY_AGENT_ID=replace_with_wecom_directory_agent_id
WECOM_DIRECTORY_SECRET=replace_with_wecom_directory_secret
WECOM_DIRECTORY_ROOT_DEPARTMENT_NAME=联软科技集团
WECOM_DIRECTORY_PAGE_SIZE=100

# 企业微信主动通知
WECOM_NOTIFY_CORP_ID=replace_with_wecom_notify_corp_id
WECOM_NOTIFY_AGENT_ID=replace_with_wecom_notify_agent_id
WECOM_NOTIFY_SECRET=replace_with_wecom_notify_secret
WECOM_NOTIFY_REAL_MESSAGE_ENABLED=false
WECOM_NOTIFY_TEST_USER_ID=replace_with_notify_test_user_id
WECOM_APP_MESSAGE_MIN_INTERVAL_MS=3000
WECOM_APP_MESSAGE_MAX_RETRIES=2
WECOM_APP_MESSAGE_RATE_LIMIT_RETRY_DELAYS_MS=60000,180000,300000
WECOM_PROACTIVE_BULK_MAX_CONCURRENCY=1

# 日报联调与生产调度脚本（仅供运维脚本读取，后端应用本身不直接消费）
# 建议先使用受控管理员账号做登录换取会话，再由脚本调用日报 cron 接口。
SCHEDULER_BASE_URL=https://analytics.company.com
SCHEDULER_LOGIN=replace_with_scheduler_login
SCHEDULER_PASSWORD=replace_with_scheduler_password
# 如登录时需要显式 corpId，可按需取消注释。
# SCHEDULER_CORP_ID=replace_with_crm_corp_id

# 合同审核存储与标准包
CONTRACT_REVIEW_STORAGE_DIR=/srv/crm-intelligent-analytics/shared/.runtime/contract-review
CONTRACT_REVIEW_MAX_FILE_SIZE_MB=10
CONTRACT_REVIEW_SKILL_PACK_ROOT_DIR=/srv/crm-intelligent-analytics/current/backend/resources/contract-review-skill-packs
CONTRACT_REVIEW_SKILL_PACK_CODE=company-commercial-v1
CONTRACT_REVIEW_AI_TIMEOUT_MS=150000
CONTRACT_REVIEW_AI_MAX_PARALLEL_GROUPS=1
CONTRACT_REVIEW_AI_SUPPLEMENTAL_TIMEOUT_MS=45000
CONTRACT_REVIEW_AI_SUPPLEMENTAL_MAX_CHECKS_PER_BATCH=1
CONTRACT_REVIEW_REVIEWER_ROLE_IDS=role_admin
CONTRACT_REVIEW_DOWNLOADER_ROLE_IDS=role_admin

# 新增客户字段映射
CRM_CUSTOMER_CREATE_DEFAULT_CATEGORY=replace_with_customer_category_value
CRM_CUSTOMER_CREATE_DEFAULT_SOURCE=replace_with_customer_source_value
CRM_CUSTOMER_CREATE_IT_DECISION_LOCATION_FIELD=replace_with_customer_it_decision_location_field_key
CRM_CUSTOMER_CREATE_UNIFIED_SOCIAL_CREDIT_CODE_FIELD=replace_with_customer_uscc_field_key

# 新增商机字段映射
CRM_OPPORTUNITY_CREATE_DEFAULT_STAGE=replace_with_opportunity_stage_value
CRM_OPPORTUNITY_CREATE_DEFAULT_SOURCE=replace_with_opportunity_source_value
CRM_OPPORTUNITY_CREATE_DEFAULT_KIND=replace_with_opportunity_kind_value
CRM_OPPORTUNITY_CREATE_LEAD_CODE_FIELD=replace_with_opportunity_lead_code_field_key
CRM_OPPORTUNITY_CREATE_RENEWAL_CONTRACT_CODE_FIELD=replace_with_opportunity_renewal_contract_code_field_key
CRM_OPPORTUNITY_CREATE_AGENT_FULL_NAME_FIELD=replace_with_opportunity_agent_full_name_field_key
CRM_OPPORTUNITY_CREATE_PROJECT_STATUS_FIELD=replace_with_opportunity_project_status_field_key
CRM_OPPORTUNITY_CREATE_PRE_SALES_FIELD=replace_with_opportunity_pre_sales_field_key
CRM_OPPORTUNITY_CREATE_PRODUCT_ALIAS_MAP={"云平台标准版":"replace_with_product_id"}

# 日报与 AI 灰度
DAILY_REPORT_ENABLED=true
DAILY_REPORT_INTERNAL_SCHEDULER_ENABLED=true
DAILY_REPORT_SCHEDULER_ACTOR_USER_ID=user_admin
DAILY_REPORT_REMINDER_TIME=22:00
DAILY_REPORT_CLOSE_TIME=23:59
DAILY_REPORT_SUMMARY_TIME=08:00
# 首次联调建议保持 false，待后台发送预览通过且试点组验证完成后再切换为 true。
AI_GUARDED_DIRECT_QUERY_ENABLED=false
AI_ANALYSIS_FOLLOW_UP_INTENT_ENABLED=true
AI_GROUNDED_EXPLANATION_ENABLED=true
WECOM_AI_ENTRY_INTENT_ENABLED=true
WECOM_AI_STRUCTURED_DRAFT_ENABLED=true
WECOM_AI_ENTITY_RERANK_ENABLED=true
WECOM_AI_DAILY_INSIGHT_ENABLED=true
WECOM_AI_IDLE_INTENT_TIMEOUT_MS=8000
WECOM_AI_TASK_REPLY_TIMEOUT_MS=8000
WECOM_AI_STRUCTURED_DRAFT_TIMEOUT_MS=8000

# 线上接口性能稳定治理
# SQL 审计运行态只保留近期记录，历史记录通过归档或独立存储迁移保留。
SQL_AUDIT_RUNTIME_MAX_RECORDS=5000
SQL_AUDIT_ASYNC_ENABLED=false
SQL_AUDIT_ASYNC_QUEUE_MAX_RECORDS=5000
SQL_AUDIT_ASYNC_FLUSH_INTERVAL_MS=1000
SQL_AUDIT_INDEPENDENT_STORE_ENABLED=false
SQL_AUDIT_FILE_STORE_PATH=/srv/crm-intelligent-analytics/shared/.runtime/sql-audit-records.jsonl
SQL_AUDIT_ARCHIVE_DIR=/srv/crm-intelligent-analytics/shared/.runtime/sql-audit-archive
SQL_AUDIT_ARCHIVE_KEEP_RECENT=5000
SQL_AUDIT_MIGRATION_BATCH_SIZE=500
CRM_AUTH_SESSION_USER_CACHE_TTL_MS=30000
CRM_CAPABILITY_SNAPSHOT_TTL_MS=30000
CRM_READONLY_DB_CONNECT_TIMEOUT_MS=8000
CRM_READONLY_IDENTITY_QUERY_TIMEOUT_MS=5000
CRM_READONLY_IDENTITY_QUERY_RETRY_COUNT=1

# AI-agent 自建分析库：仅用于 ODS/DWD/语义层和受控 Text-to-SQL，不直连联软生产库。
ANALYSIS_WAREHOUSE_DB_HOST=replace_with_analysis_warehouse_host
ANALYSIS_WAREHOUSE_DB_PORT=3306
ANALYSIS_WAREHOUSE_DB_NAME=crm_agent_analysis
ANALYSIS_WAREHOUSE_DB_USER=replace_with_analysis_warehouse_user
ANALYSIS_WAREHOUSE_DB_PASSWORD=replace_with_analysis_warehouse_password
ANALYSIS_WAREHOUSE_DB_CONNECT_TIMEOUT_MS=8000
ANALYSIS_WAREHOUSE_TEXT_TO_SQL_ENABLED=true
# 仅使用联软 SQLite 快照固定模板时设为 true；启用后不连接 MySQL 分析库和 Text-to-SQL。
ANALYSIS_WAREHOUSE_SQLITE_ONLY=false

# 联软 SQLite 只读快照导入：仅允许读取联软生成的只读副本或批次快照，不填写生产运行中的 SQLite 文件路径。
# 未拿到联软脱敏测试库、表结构、字段字典和快照生成规则前保持 false。
LIANRUAN_CRM_SQLITE_SNAPSHOT_ENABLED=false
LIANRUAN_CRM_SQLITE_SNAPSHOT_DIR=/srv/crm-intelligent-analytics/shared/lianruan-sqlite-snapshots
# 可选：指定某个快照文件；不填时自动读取目录下最新的 .db/.sqlite/.sqlite3 文件。
LIANRUAN_CRM_SQLITE_SNAPSHOT_FILE=
# 可选：指定联软交付的快照 SHA256；不填时优先读取同目录 snapshot-manifest.json。
LIANRUAN_CRM_SQLITE_SNAPSHOT_SHA256=
# 可选：联软真实表名与 AI-agent 资源名的映射，示例：{"customers":"crm_customers","orders":"crm_orders"}。
LIANRUAN_CRM_SQLITE_TABLE_MAP=
# 可选：单个快照文件最大读取字节数，默认 512MB。
LIANRUAN_CRM_SQLITE_SNAPSHOT_MAX_BYTES=536870912
