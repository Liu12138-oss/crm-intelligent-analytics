{
  "name": "crm-intelligent-analytics",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-local-dev.ps1",
    "dev:backend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-backend-dev.ps1",
    "dev:frontend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-frontend-dev.ps1",
    "dev:unsafe": "pnpm --parallel --filter ./backend --filter ./frontend dev",
    "build": "pnpm --dir backend build && pnpm --dir frontend build",
    "test": "pnpm --dir backend test && pnpm --dir frontend test:unit",
    "lint": "pnpm --dir backend lint && pnpm --dir frontend lint",
    "generate:crm-analysis-300-matrix": "pnpm --dir backend exec tsx ../scripts/generate-crm-analysis-300-question-matrix.ts"
  },
  "devDependencies": {
    "@fission-ai/openspec": "1.3.1",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^9.32.0",
    "vue-eslint-parser": "^10.1.1"
  },
  "pnpm": {
    "overrides": {
      "@playwright/test": "1.58.2",
      "@types/node": "20.19.37",
      "@typescript-eslint/eslint-plugin": "8.57.2",
      "@typescript-eslint/parser": "8.57.2",
      "@vue/compiler-core": "3.5.30",
      "@vue/compiler-dom": "3.5.30",
      "@vue/compiler-sfc": "3.5.30",
      "@vue/compiler-ssr": "3.5.30",
      "@vue/reactivity": "3.5.30",
      "@vue/runtime-core": "3.5.30",
      "@vue/runtime-dom": "3.5.30",
      "@vue/server-renderer": "3.5.30",
      "@vue/shared": "3.5.30",
      "@vue/test-utils": "2.4.6",
      "@wecom/aibot-node-sdk": "1.0.4",
      "element-plus": "2.13.7",
      "mysql2": "3.20.0",
      "ts-jest": "29.4.6",
      "tsx": "4.21.0",
      "vite": "6.4.1",
      "vue": "3.5.30",
      "zod-to-json-schema": "3.25.1"
    }
  }
}
