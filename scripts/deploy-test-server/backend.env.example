# 测试服务器后端环境变量示例
# 使用方式：
# 1. 首次初始化后，将本文件内容复制到 /srv/crm-intelligent-analytics/shared/backend.env。
# 2. 把占位值替换成测试环境真实值。
# 3. 不要把填写真实密钥后的 backend.env 提交到 GitHub。

NODE_ENV=production
PORT=3001

# 如果测试服务器暂时没有域名，可以先使用 http://测试服务器IP/insight
APP_WEB_BASE_URL=http://测试服务器IP/insight
VITE_API_BASE_URL=http://测试服务器IP/insight
VITE_APP_BASE_PATH=/insight/

# 生产或测试环境必须使用至少 32 位随机字符串。
AI_PROFILE_MASTER_KEY=请替换为至少32位随机字符串

# AI 默认配置。只验证页面启动时可以先填占位；需要真实 AI 对话时必须填写真实值。
ANALYSIS_AI_BASE_URL=请替换为AI网关地址
ANALYSIS_AI_MODEL_PROVIDER=internal-openai-gateway
ANALYSIS_AI_MODEL=请替换为模型名
ANALYSIS_AI_WIRE_API=responses
ANALYSIS_AI_STRUCTURED_OUTPUT_MODE=json_schema
OPENAI_API_KEY=请替换为AI密钥

# 企业微信机器人。需要联调机器人时必须填写真实值。
WECOM_BOT_ID=请替换为企业微信机器人ID
WECOM_BOT_SECRET=请替换为企业微信机器人Secret
WECOM_BOT_SIGNATURE=请替换为企业微信机器人签名
