# 测试服务器后端环境变量示例
# 使用方式：
# 1. 首次初始化后，将本文件内容复制到 /srv/crm-intelligent-analytics/shared/backend.env。
# 2. 把占位值替换成测试环境真实值。
# 3. 不要把填写真实密钥后的 backend.env 提交到 GitHub。

NODE_ENV=production
PORT=3001

# 如果测试服务器暂时没有域名，可以先使用 http://测试服务器IP/insight
APP_WEB_BASE_URL=http://测试服务器IP/insight
VITE_API_BASE_URL=http://测试服务器IP/insight
VITE_APP_BASE_PATH=/insight/

# 生产或测试环境必须使用至少 32 位随机字符串。
AI_PROFILE_MASTER_KEY=请替换为至少32位随机字符串

# AI 默认配置。只验证页面启动时可以先填占位；需要真实 AI 对话时必须填写真实值。
ANALYSIS_AI_BASE_URL=请替换为AI网关地址
ANALYSIS_AI_MODEL_PROVIDER=请替换为供应商代码
ANALYSIS_AI_MODEL=请替换为模型名
ANALYSIS_AI_WIRE_API=chat_completions
ANALYSIS_AI_STRUCTURED_OUTPUT_MODE=json_object
OPENAI_API_KEY=请替换为AI密钥

# CRM 标准 OpenAPI。系统会自动在 BASE_URL 后拼接 /auth/token 获取访问令牌。
CRM_STANDARD_OPEN_API_BASE_URL=请替换为CRM标准OpenAPI基础地址
CRM_STANDARD_OPEN_API_APP_KEY=请替换为CRM标准OpenAPI的AppKey
CRM_STANDARD_OPEN_API_APP_SECRET=请替换为CRM标准OpenAPI的AppSecret
CRM_STANDARD_OPEN_API_TIMEOUT_MS=12000
CRM_STANDARD_OPEN_API_TOKEN_CACHE_BUFFER_SECONDS=60
CRM_STANDARD_OPEN_API_ACCESS_MODE=bound-user

# 企业微信机器人。需要联调机器人时必须填写真实值。
WECOM_BOT_ID=请替换为企业微信机器人ID
WECOM_BOT_SECRET=请替换为企业微信机器人Secret
WECOM_ENABLE_SDK_TRANSPORT=true
WECOM_BOT_WS_URL=wss://openws.work.weixin.qq.com

# 仅 HTTP 回调入口需要签名校验；长连接 SDK 模式不需要填写。
# WECOM_BOT_SIGNATURE=请替换为企业微信HTTP回调签名
